{
  "detectiveOptions": {
    "ts": {
      "skipTypeImports": false
    }
  },
  "fileExtensions": ["ts", "tsx"],
  "excludeRegExp": [
    "node_modules/",
    "dist/",
    "\\.test\\.ts$",
    "\\.spec\\.ts$"
  ],
  "comment": "Configuration for madge circular dependency detection",
  "knownCircularDependencies": {
    "core/types": "types/index.ts -> types/service.ts -> types/envelope.ts -> types/platform.ts -> types/index.ts"
  }
}
