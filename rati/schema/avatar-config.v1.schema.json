    { "$ref": "./expansions/scheduling.v1.schema.json" },
    { "$ref": "./expansions/behavior.v1.schema.json" },
    { "$ref": "./expansions/tools-secrets.v1.schema.json" },
    { "$ref": "./expansions/voice.v1.schema.json" },
    { "$ref": "./expansions/solana.v1.schema.json" },
    { "$ref": "./expansions/energy.v1.schema.json" },
    { "$ref": "./expansions/dnd.v1.schema.json" },
    { "$ref": "./expansions/nft-avatar.v1.schema.json" }
