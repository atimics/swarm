{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.rati.chat/rati/schema/expansions/tools-secrets.v1.schema.json",
  "title": "RATi Avatar Tools & Secrets Expansion (v1)",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Enabled tool names for the avatar runtime."
    },
    "secrets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Secret IDs required for this avatar (AWS Secrets Manager names/keys)."
    }
  },
  "required": ["tools", "secrets"]
}
