{
  "name": "@swarm/core",
  "version": "1.0.0",
  "description": "Core types, services, and platform adapters for the swarm",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "bun": "./src/types/index.ts",
      "types": "./src/types/index.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./platforms": {
      "bun": "./src/platforms/index.ts",
      "types": "./src/platforms/index.ts",
      "import": "./dist/platforms/index.js",
      "default": "./dist/platforms/index.js"
    },
    "./processors": {
      "bun": "./src/processors/index.ts",
      "types": "./src/processors/index.ts",
      "import": "./dist/processors/index.js",
      "default": "./dist/processors/index.js"
    },
    "./services": {
      "bun": "./src/services/index.ts",
      "types": "./src/services/index.ts",
      "import": "./dist/services/index.js",
      "default": "./dist/services/index.js"
    },
    "./errors": {
      "bun": "./src/errors/index.ts",
      "types": "./src/errors/index.ts",
      "import": "./dist/errors/index.js",
      "default": "./dist/errors/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --build --watch",
    "test": "bun test",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1032.0",
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/client-secrets-manager": "^3.1032.0",
    "@aws-sdk/client-sqs": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.98.0",
    "grammy": "^1.42.0",
    "jimp": "^1.6.1",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.29.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@types/aws-lambda": "^8.10.0"
  }
}
