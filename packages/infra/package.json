{
  "name": "@swarm/infra",
  "version": "1.0.0",
  "description": "CDK infrastructure for the swarm framework",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
