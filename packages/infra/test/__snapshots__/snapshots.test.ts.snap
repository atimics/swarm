                    "",
                    [
                      "origin-access-identity/cloudfront/",
                      {
                        "Ref": "AdminUiOAI860F6465",
                      },
                    ],
                  ],
                },
              },
            },
          ],
          "PriceClass": "PriceClass_100",
          "WebACLId": {
            "Fn::GetAtt": [
              "AdminUiCloudFrontWebAcl2D235F19",
              "Arn",
            ],
          },
        },
      },
      "Type": "AWS::CloudFront::Distribution",
    },
    "AdminUiOAI860F6465": {
      "Properties": {
        "CloudFrontOriginAccessIdentityConfig": {
          "Comment": "OAI for Admin UI (staging)",
        },
      },
      "Type": "AWS::CloudFront::CloudFrontOriginAccessIdentity",
    },
    "AdminUiSpaRewriteFunction6526AF19": {
      "Properties": {
        "AutoPublish": true,
        "FunctionCode": 
"function handler(event) {
  var request = event.request;
  var uri = request.uri;

  // Never rewrite API requests
  if (uri === '/api' || uri.indexOf('/api/') === 0) {
    return request;
  }

  // If the URI looks like a static file (has an extension), leave it alone
  if (uri.indexOf('.') !== -1) {
    return request;
  }

  // Rewrite all other paths to the SPA entrypoint
  request.uri = '/index.html';
  return request;
}"
,
        "FunctionConfig": {
          "Comment": "Rewrite non-file routes to /index.html for SPA routing (excluding /api/*)",
          "Runtime": "cloudfront-js-1.0",
        },
        "Name": "us-east-1TestAdminUiExistaRewriteFunctionAF8DE2A4",
      },
      "Type": "AWS::CloudFront::Function",
    },
  },
  "Rules": {
    "CheckBootstrapVersion": {
      "Assertions": [
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Contains": [
                  [
                    "1",
                    "2",
                    "3",
                    "4",
                    "5",
                  ],
                  {
                    "Ref": "BootstrapVersion",
                  },
                ],
              },
            ],
          },
          "AssertDescription": "CDK bootstrap stack version 6 required. Please run 'cdk bootstrap' with a recent version of the CDK CLI.",
        },
      ],
    },
  },
}
`;

