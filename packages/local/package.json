{
  "name": "@swarm/local",
  "version": "1.0.0",
  "description": "Local-first backends for aws-swarm (SQLite, filesystem, in-memory queue)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc -b",
    "dev": "bun run src/server.ts",
    "test": "bun test",
    "lint": "eslint --max-warnings 0 src/"
  },
  "dependencies": {
    "@swarm/admin-api": "workspace:*",
    "@swarm/core": "workspace:*",
    "@swarm/mcp-server": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "grammy": "^1.42.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
