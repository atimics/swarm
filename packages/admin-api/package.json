    "@aws-sdk/client-ecs": "^3.1004.0",
    "@aws-sdk/client-dynamodb": "^3.1004.0",
    "@aws-sdk/client-kms": "^3.1004.0",
    "@aws-sdk/client-lambda": "^3.1004.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-secrets-manager": "^3.1004.0",
    "@aws-sdk/client-sqs": "^3.1004.0",
    "@aws-sdk/lib-dynamodb": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@openrouter/sdk": "0.9.11",
