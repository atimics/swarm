{
  "name": "@swarm/admin-api",
  "version": "1.0.0",
  "description": "Admin API for swarm avatar management",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --build --watch",
    "test": "bun test",
    "lint": "eslint src/",
    "test:tools": "tsx src/test-tool-calling.ts --direct --aws",
    "test:tools:verbose": "tsx src/test-tool-calling.ts --direct --aws --verbose"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1004.0",
