# Admin UI environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit real credentials to .env — use .env.local instead.

# API endpoint (defaults to /api if not set)
VITE_API_URL=https://your-api-endpoint.execute-api.us-east-1.amazonaws.com

# Privy authentication
VITE_PRIVY_APP_ID=your_privy_app_id_here

# Crossmint (used in CI/CD workflows)
VITE_CROSSMINT_PROJECT_ID=your_crossmint_project_id_here

# Optional: enable Privy embedded wallets (true/false)
VITE_PRIVY_ENABLE_EMBEDDED_WALLETS=false
