# syntax=docker/dockerfile:1.7

# Discord Gateway Worker
# Multi-tenant ECS Fargate task that connects to Discord Gateway WebSocket
# and routes messages into the shared SQS pipeline.
#
# Build context should be the repo root so we can access core + handlers.
# Usage: docker build -f packages/handlers/Dockerfile.discord-gateway .

FROM node:20-slim AS builder

WORKDIR /build
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

# Copy workspace manifests FIRST (before source) so pnpm install is cached
# unless package.json or pnpm-lock.yaml changes.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json ./
COPY packages/core/package.json packages/core/tsconfig.json packages/core/
COPY packages/mcp-server/package.json packages/mcp-server/tsconfig.json packages/mcp-server/
COPY packages/sticker-engine/package.json packages/sticker-engine/tsconfig.json packages/sticker-engine/
COPY packages/handlers/package.json packages/handlers/tsconfig.json packages/handlers/

# Install dependencies. The BuildKit cache mount survives between GitHub
# Actions builds through the GHA cache configured by the CDK asset.
RUN corepack enable && corepack prepare pnpm@10.19.0 --activate && pnpm config set store-dir /pnpm/store
RUN --mount=type=cache,id=discord-gateway-pnpm-store,target=/pnpm/store \
    pnpm install --frozen-lockfile --prefer-offline --filter @swarm/core --filter @swarm/mcp-server --filter @swarm/sticker-engine --filter @swarm/handlers

# Copy source AFTER install so source-only changes don't bust the install cache
ARG DISCORD_GATEWAY_SOURCE_HASH
RUN echo "" > /tmp/discord-gateway-source-hash
COPY packages/core/src/ packages/core/src/
COPY packages/mcp-server/src/ packages/mcp-server/src/
COPY packages/sticker-engine/src/ packages/sticker-engine/src/
COPY packages/handlers/src/ packages/handlers/src/

RUN pnpm --filter @swarm/core build
RUN pnpm --filter @swarm/mcp-server build
RUN pnpm --filter @swarm/sticker-engine build
RUN pnpm --filter @swarm/handlers build

# ─── Production image ─────────────────────────────────────────────────────────

FROM node:20-slim

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    ffmpeg \
    procps \
    && apt-get clean

RUN useradd -m -s /bin/bash swarm

WORKDIR /home/swarm/app

# Copy built outputs
COPY --chown=swarm:swarm --from=builder /build/packages/handlers/dist/ ./dist/
COPY --chown=swarm:swarm --from=builder /build/packages/handlers/package.json ./package.json
# Copy workspace package manifests for dependency merge
COPY --from=builder /build/packages/core/package.json /tmp/swarm-core-package.json
COPY --from=builder /build/packages/mcp-server/package.json /tmp/swarm-mcp-server-package.json
COPY --from=builder /build/packages/sticker-engine/package.json /tmp/swarm-sticker-engine-package.json

# Merge deps from all workspace packages and strip workspace: protocol references.
# Core, mcp-server, and sticker-engine have their own deps (e.g.,
# @anthropic-ai/sdk, jimp, sharp) that must be installed so barrel imports don't
# fail at runtime.
RUN node -e "\
const fs=require('fs');\
const h=require('./package.json');\
const c=require('/tmp/swarm-core-package.json');\
const m=require('/tmp/swarm-mcp-server-package.json');\
const s=require('/tmp/swarm-sticker-engine-package.json');\
const deps={...h.dependencies};\
for(const pkg of [c,m,s]){for(const[k,v]of Object.entries(pkg.dependencies||{})){if(!deps[k])deps[k]=v}}\
for(const k of Object.keys(deps)){if(String(deps[k]).startsWith('workspace:'))delete deps[k]}\
h.dependencies=deps;\
fs.writeFileSync('package.json',JSON.stringify(h,null,2))"
RUN --mount=type=cache,id=discord-gateway-npm-cache,target=/root/.npm \
    npm install --omit=dev --prefer-offline --no-audit --no-fund
RUN node -e "\
const fs=require('fs');\
for(const file of ['node_modules/@discordjs/voice/dist/index.js','node_modules/@discordjs/voice/dist/index.mjs']){\
  let source=fs.readFileSync(file,'utf8');\
  source=source.replaceAll('?v=4','?v=8');\
  source=source.replace('token: this.state.connectionOptions.token\\n        }\\n      };','token: this.state.connectionOptions.token,\\n          max_dave_protocol_version: 0\\n        }\\n      };');\
  fs.writeFileSync(file,source);\
}"

# Copy workspace packages after npm install so npm prune cannot remove them.
COPY --chown=swarm:swarm --from=builder /build/packages/core/dist/ ./node_modules/@swarm/core/dist/
COPY --chown=swarm:swarm --from=builder /build/packages/core/package.json ./node_modules/@swarm/core/package.json
COPY --chown=swarm:swarm --from=builder /build/packages/mcp-server/dist/ ./node_modules/@swarm/mcp-server/dist/
COPY --chown=swarm:swarm --from=builder /build/packages/mcp-server/package.json ./node_modules/@swarm/mcp-server/package.json
COPY --chown=swarm:swarm --from=builder /build/packages/sticker-engine/dist/ ./node_modules/@swarm/sticker-engine/dist/
COPY --chown=swarm:swarm --from=builder /build/packages/sticker-engine/package.json ./node_modules/@swarm/sticker-engine/package.json

USER swarm

ENV NODE_ENV=production

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD pgrep -f "node.*discord-gateway" || exit 1

CMD ["node", "dist/discord/discord-gateway-shared.js"]
