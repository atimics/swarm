{
  "name": "@swarm/handlers",
  "version": "1.0.0",
  "description": "Lambda handlers for the swarm framework",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build && cp package.json dist/",
    "postbuild:ts": "cp package.json dist/",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --build --watch",
    "test": "bun test",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.995.0",
    "@aws-sdk/client-cloudwatch": "^3.995.0",
    "@aws-sdk/client-lambda": "^3.995.0",
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/client-secrets-manager": "^3.995.0",
    "@aws-sdk/client-sqs": "^3.995.0",
    "@aws-sdk/lib-dynamodb": "^3.995.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@swarm/core": "workspace:*",
    "@swarm/mcp-server": "workspace:*",
    "grammy": "^1.40.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0"
  }
}
