{
  "name": "@swarm/handlers",
  "version": "1.0.0",
  "description": "Lambda handlers for the swarm framework",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build && cp package.json dist/",
    "postbuild:ts": "cp package.json dist/",
    "typecheck": "tsc -b",
    "watch": "tsc --build --watch",
    "test": "bun test",
    "lint": "eslint --max-warnings 70 src/"
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.1032.0",
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/client-cloudwatch": "^3.1032.0",
    "@aws-sdk/client-lambda": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/client-secrets-manager": "^3.1032.0",
    "@aws-sdk/client-sqs": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@discordjs/voice": "0.18.0",
    "@noble/ciphers": "^1.3.0",
    "@swarm/core": "workspace:*",
    "@swarm/mcp-server": "workspace:*",
    "@swarm/sticker-engine": "workspace:*",
    "grammy": "^1.42.0",
    "opusscript": "^0.0.8",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0"
  }
}
