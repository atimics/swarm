{
  "name": "@swarm/sticker-engine",
  "version": "1.0.0",
  "description": "Sticker processing engine for Telegram and web formats",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./formats/web": {
      "bun": "./src/formats/web.ts",
      "types": "./src/formats/web.ts",
      "import": "./dist/formats/web.js",
      "default": "./dist/formats/web.js"
    },
    "./formats/telegram": {
      "bun": "./src/formats/telegram.ts",
      "types": "./src/formats/telegram.ts",
      "import": "./dist/formats/telegram.js",
      "default": "./dist/formats/telegram.js"
    },
    "./core/*": {
      "bun": "./src/core/*",
      "types": "./src/core/*",
      "import": "./dist/core/*",
      "default": "./dist/core/*"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc -b",
    "watch": "tsc --build --watch",
    "test": "bun test",
    "lint": "eslint --max-warnings 70 src/",
    "dev": "tsc --build --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "@img/sharp-darwin-arm64": "^0.34.5",
    "@img/sharp-linux-x64": "^0.34.5"
  }
}
