{
  "name": "@swarm/claude-code-worker",
  "version": "1.0.0",
  "description": "Claude Code worker for AWS Swarm - processes coding tasks using Claude Code CLI",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.114",
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/client-sqs": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
