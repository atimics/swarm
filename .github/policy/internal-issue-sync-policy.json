{
  "version": "1",
  "defaults": {
    "repo": "cenetex/aws-swarm",
    "dryRun": true,
    "status": "open",
    "limit": 100,
    "assignCopilot": false,
    "markerPrefix": "internal-issue-sync:id=",
    "sourceLabel": "internal-issues",
    "titlePrefix": "[auto-issue]",
    "labels": [
      "type:bug"
    ]
  },
  "severityRules": {
    "critical": {
      "labels": [
        "priority:high"
      ],
      "assignCopilot": true
    },
    "high": {
      "labels": [
        "priority:high"
      ],
      "assignCopilot": true
    },
    "medium": {
      "labels": [
        "priority:medium"
      ],
      "assignCopilot": false
    },
    "low": {
      "labels": [
        "priority:low"
      ],
      "assignCopilot": false
    }
  },
  "categoryRules": {
    "feature_request": {
      "labels": [
        "type:feature"
      ],
      "assignCopilot": true
    },
    "warning": {
      "labels": [
        "type:tech-debt"
      ]
    }
  },
  "subsystemRules": {
    "telegram": {
      "labels": [
        "package:handlers"
      ]
    },
    "chat": {
      "labels": [
        "package:admin"
      ]
    },
    "llm": {
      "labels": [
        "package:admin"
      ]
    },
    "state": {
      "labels": [
        "package:core"
      ]
    },
    "webhook": {
      "labels": [
        "package:handlers"
      ]
    }
  }
}
