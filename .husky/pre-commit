#!/usr/bin/env sh
set -e

# Fast pre-commit checks: keep commits quick.
# Full suite runs on pre-push (see .husky/pre-push).
# Skip with: SKIP_PRECOMMIT=1 git commit
if [ "${SKIP_PRECOMMIT:-}" = "1" ] || [ "${SKIP_PRECOMMIT:-}" = "true" ]; then
	echo "pre-commit: SKIP_PRECOMMIT set; skipping checks"
	exit 0
fi

# Verify lockfile is in sync with all package.json files
echo "pre-commit: lockfile check"
pnpm install --frozen-lockfile --ignore-scripts > /dev/null 2>&1 || {
	echo "ERROR: pnpm-lock.yaml is out of date."
	echo "       Run 'pnpm install' and commit the updated lockfile."
	exit 1
}

echo "pre-commit: pnpm lint"
pnpm lint
