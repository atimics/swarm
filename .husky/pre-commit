#!/usr/bin/env sh
set -e

# Fast pre-commit checks: keep commits quick.
# Full suite runs on pre-push (see .husky/pre-push).
# Skip with: SKIP_PRECOMMIT=1 git commit
if [ "${SKIP_PRECOMMIT:-}" = "1" ] || [ "${SKIP_PRECOMMIT:-}" = "true" ]; then
	echo "pre-commit: SKIP_PRECOMMIT set; skipping checks"
	exit 0
fi

# Check for unreviewed issues (critical issues block commit)
# Skip with: SKIP_ISSUE_CHECK=1 git commit
if [ -f "scripts/check-issues.sh" ]; then
	./scripts/check-issues.sh
fi

echo "pre-commit: pnpm lint"
pnpm lint
