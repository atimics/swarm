{
  "name": "aws-swarm",
  "version": "1.0.0",
  "description": "Social media avatar swarm framework for AWS",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:parallel": "pnpm -r --parallel build",
    "typecheck": "pnpm -r --parallel typecheck",
    "dev": "pnpm -r --parallel dev",
    "test": "bun test",
    "lint": "pnpm -r --parallel lint",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "deploy": "pnpm --filter @swarm/infra deploy",
    "deploy:all": "pnpm --filter @swarm/infra cdk deploy --all",
    "deploy:avatar": "pnpm --filter @swarm/infra cdk deploy",
    "deploy:dev": "pnpm --filter @swarm/infra cdk deploy -c environment=dev",
    "deploy:prod": "pnpm --filter @swarm/infra cdk deploy -c environment=prod",
    "synth": "pnpm --filter @swarm/infra synth",
    "cdk": "pnpm --filter @swarm/infra cdk",
    "test:persona": "node scripts/test-persona.mjs",
    "test:browser": "node scripts/test-browser.mjs",
    "prepare": "husky"
  },
  "keywords": [
    "aws",
    "lambda",
    "telegram",
    "twitter",
    "ai",
    "avatars",
    "solana"
  ],
  "author": "",
  "license": "MIT",
  "lint-staged": {
    "packages/*/src/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.0.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.52.0",
    "vitest": "^2.0.0",
    "yaml": "^2.6.0"
  }
}
