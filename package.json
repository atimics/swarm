{
  "name": "aws-swarm",
  "version": "0.1.68",
  "description": "Social media avatar swarm framework for AWS",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:parallel": "pnpm -r --parallel build",
    "typecheck": "pnpm -r --parallel typecheck",
    "dev": "pnpm -r --parallel dev",
    "test": "bun test",
    "test:ci": "bun test",
    "test:plan": "RUN_PLAN_TESTS=1 bun test packages/plan-tests",
    "lint": "pnpm -r --parallel lint",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "deploy": "pnpm --filter @swarm/infra deploy",
    "deploy:all": "pnpm --filter @swarm/infra cdk deploy --all",
    "deploy:avatar": "pnpm --filter @swarm/infra cdk deploy",
    "deploy:dev": "pnpm --filter @swarm/infra cdk deploy -c environment=dev",
    "deploy:staging": "pnpm --filter @swarm/infra cdk deploy -c environment=staging",
    "deploy:prod": "pnpm --filter @swarm/infra cdk deploy -c environment=prod",
    "synth": "pnpm --filter @swarm/infra synth",
    "synth:staging": "pnpm --filter @swarm/infra cdk synth -c environment=staging",
    "cdk": "pnpm --filter @swarm/infra cdk",
    "diff:staging": "pnpm --filter @swarm/infra cdk diff -c environment=staging",
    "test:browser": "node scripts/test-browser.mjs",
    "canary:telegram": "bun run scripts/telegram-canary.ts",
    "prepare": "husky",
    "version:bump": "node -e \"const p=require('./package.json');const [a,b,c]=p.version.split('.').map(Number);p.version=[a,b,c+1].join('.');require('fs').writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n');console.log('Bumped to '+p.version)\""
  },
  "keywords": [
    "aws",
    "lambda",
    "telegram",
    "twitter",
    "ai",
    "avatars",
    "solana"
  ],
  "author": "",
  "license": "MIT",
  "lint-staged": {
    "packages/*/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@eslint/js": "^9.39.2",
    "@swarm/core": "workspace:*",
    "@types/node": "^22.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.52.0",
    "yaml": "^2.6.0"
  },
  "pnpm": {
    "overrides": {
      "@solana/kit": "5.4.0",
      "axios": "1.12.0",
      "diff": "5.2.2",
      "esbuild": "0.27.2",
      "h3": "1.15.5",
      "hono": "4.11.9",
      "js-yaml": "4.1.1",
      "lodash": "4.17.23",
      "nanoid": "3.3.8",
      "serialize-javascript": "6.0.2",
      "@aws-sdk/xml-builder>fast-xml-parser": "5.3.4"
    }
  }
}
