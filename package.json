{
  "name": "aws-swarm",
  "version": "1.0.0",
  "description": "Social media agent swarm framework for AWS",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "deploy": "pnpm --filter @swarm/infra deploy",
    "deploy:all": "pnpm --filter @swarm/infra cdk deploy --all",
    "deploy:agent": "pnpm --filter @swarm/infra cdk deploy",
    "deploy:dev": "pnpm --filter @swarm/infra cdk deploy -c environment=dev",
    "deploy:prod": "pnpm --filter @swarm/infra cdk deploy -c environment=prod",
    "synth": "pnpm --filter @swarm/infra synth",
    "cdk": "pnpm --filter @swarm/infra cdk",
    "test:persona": "node scripts/test-persona.mjs"
  },
  "keywords": ["aws", "lambda", "telegram", "twitter", "ai", "agents", "solana"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "yaml": "^2.6.0"
  }
}
