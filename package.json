{
  "name": "aws-swarm",
  "description": "Social media avatar swarm framework for AWS",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "build": "tsc --build && cp packages/handlers/package.json packages/handlers/dist/ && pnpm --filter @swarm/admin-ui build && pnpm --filter @swarm/profile-page build",
    "build:ts": "tsc --build",
    "build:parallel": "pnpm -r --parallel build",
    "typecheck": "tsc -b && pnpm --filter @swarm/admin-ui typecheck",
    "dev": "pnpm -r --parallel dev",
    "test": "bun test",
    "test:coverage": "bun test --coverage 2>&1 | tee /tmp/cov.txt && ./scripts/check-coverage.sh /tmp/cov.txt 40",
    "test:ci": "bun test",
    "lint": "pnpm -r --parallel lint",
    "check:circular": "node scripts/check-circular-deps.mjs",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "deploy": "pnpm --filter @swarm/infra deploy",
    "deploy:all": "pnpm --filter @swarm/infra cdk deploy --all",
    "deploy:avatar": "pnpm --filter @swarm/infra cdk deploy",
    "deploy:dev": "pnpm --filter @swarm/infra cdk deploy -c environment=dev",
    "deploy:staging": "pnpm --filter @swarm/infra cdk deploy -c environment=staging",
    "deploy:prod": "pnpm --filter @swarm/infra cdk deploy -c environment=prod",
    "synth": "pnpm --filter @swarm/infra synth",
    "synth:staging": "pnpm --filter @swarm/infra cdk synth -c environment=staging",
    "cdk": "pnpm --filter @swarm/infra cdk",
    "diff:staging": "pnpm --filter @swarm/infra cdk diff -c environment=staging",
    "test:browser": "node scripts/test-browser.mjs",
    "issues:mirror": "node scripts/sync-issues-mirror.mjs",
    "issues:sync:internal": "node scripts/sync-internal-issues-to-github.mjs --config .github/policy/internal-issue-sync-policy.json --dry-run",
    "issues:sync:internal:files": "INTERNAL_ISSUE_SOURCE=files INTERNAL_ISSUE_SOURCE_DIR=issues/staging node scripts/sync-internal-issues-to-github.mjs --config .github/policy/internal-issue-sync-policy.json --dry-run",
    "issues:sync:internal:apply": "node scripts/sync-internal-issues-to-github.mjs --config .github/policy/internal-issue-sync-policy.json --apply",
    "canary:telegram": "bun run scripts/telegram-canary.ts",
    "canary:twitter": "ENVIRONMENT=${ENVIRONMENT:-staging} bun run scripts/twitter-canary.ts",
    "prepare": "husky",
    "release": "./scripts/release.sh"
  },
  "keywords": [
    "aws",
    "lambda",
    "telegram",
    "twitter",
    "ai",
    "avatars",
    "solana"
  ],
  "author": "",
  "license": "MIT",
  "lint-staged": {
    "packages/*/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1004.0",
    "@aws-sdk/client-dynamodb": "^3.1004.0",
    "@aws-sdk/client-secrets-manager": "^3.1004.0",
    "@aws-sdk/lib-dynamodb": "^3.1004.0",
    "@eslint/js": "^9.39.3",
    "@swarm/core": "workspace:*",
    "@types/node": "^22.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "madge": "^8.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "yaml": "^2.8.3"
  },
  "pnpm": {
    "auditConfig": {
      "ignoreCves": [
        "CVE-2025-3194"
      ]
    },
    "overrides": {
      "@solana/kit": "5.4.0",
      "axios": "1.13.5",
      "diff": "5.2.2",
      "esbuild": "0.27.3",
      "h3": "1.15.6",
      "fast-xml-parser": "5.5.6",
      "hono": "4.12.8",
      "js-yaml": "4.1.1",
      "lodash": "4.17.23",
      "minimatch": "10.2.3",
      "nanoid": "3.3.8",
      "qs": "6.14.2",
      "serialize-javascript": "6.0.2",
      "ajv@^6": "6.14.0",
      "bn.js": "5.2.3",
      "@hono/node-server": "1.19.11",
      "express-rate-limit": "8.3.0",
      "rollup": "4.59.0",
      "flatted": "3.4.2",
      "socket.io-parser": "4.2.6",
      "undici": "7.24.0"
    }
  }
}
